# Security headers for every response. CSP is enforceable since 2026-07-07:
# ALL JS lives in assets/*.js (no inline <script>, no onclick attributes —
# app.js routes [data-action] clicks). Inline <style> blocks and style=""
# attributes are still used, hence 'unsafe-inline' for styles only.
# External allowances: Font Awesome CSS + webfonts from cdnjs.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/products.json
  Cache-Control: public, max-age=300, must-revalidate

/assets/*
  Cache-Control: public, max-age=86400

/style.css
  Cache-Control: public, max-age=86400

# /images/* is cached immutably for 30 days — great for product/review art that
# never changes under the same name.
/images/*
  Cache-Control: public, max-age=2592000, immutable

# Payment QR images CAN be replaced in place and must NEVER serve stale (money
# path). These override the immutable rule above (listed after it + more
# specific, so they win under either CF precedence rule). Browsers always
# revalidate -> a swapped QR is picked up on the next load, no rename needed.
# (Stable filenames on purpose: fingerprint-renaming broke when a deploy shipped
# the HTML but not the renamed binary. Trailing '*' still covers any future
# versioned name if you ever do fingerprint one.)
/images/kpay-qr*
  Cache-Control: public, max-age=0, must-revalidate
/images/wavepay-qr*
  Cache-Control: public, max-age=0, must-revalidate
/images/ayapay-qr*
  Cache-Control: public, max-age=0, must-revalidate
